generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model PricePoint {
  id            String   @default(uuid())
  assetA        String   @map("asset_a")
  assetB        String   @map("asset_b")
  pairKey       String   @map("pair_key")
  source        String
  poolId        String?  @map("pool_id")
  price         Decimal  @db.Decimal(36, 18)
  baseVolume    Decimal  @map("base_volume") @db.Decimal(36, 7)
  counterVolume Decimal  @map("counter_volume") @db.Decimal(36, 7)
  ledger        Int
  timestamp     DateTime
  eventId       String?  @map("event_id")

  @@id([id, timestamp])
  @@index([pairKey, timestamp(sort: Desc)])
  @@index([pairKey, source, timestamp(sort: Desc)])
  @@map("price_points")
}

model PoolSnapshot {
  id          String   @default(uuid())
  poolId      String   @map("pool_id")
  assetA      String   @map("asset_a")
  assetB      String   @map("asset_b")
  reserveA    Decimal  @map("reserve_a") @db.Decimal(36, 7)
  reserveB    Decimal  @map("reserve_b") @db.Decimal(36, 7)
  spotPrice   Decimal  @map("spot_price") @db.Decimal(36, 18)
  totalShares Decimal? @map("total_shares") @db.Decimal(36, 7)
  feeBp       Int      @default(30) @map("fee_bp")
  ledger      Int
  timestamp   DateTime

  @@id([id, timestamp])
  @@index([poolId, timestamp(sort: Desc)])
  @@map("pool_snapshots")
}

model PriceAggregate {
  pairKey     String   @map("pair_key")
  window      String
  bucket      DateTime
  vwap        Decimal  @db.Decimal(36, 18)
  sdexVwap    Decimal? @map("sdex_vwap") @db.Decimal(36, 18)
  ammVwap     Decimal? @map("amm_vwap") @db.Decimal(36, 18)
  volume      Decimal  @default(0) @db.Decimal(36, 7)
  sdexVolume  Decimal? @default(0) @map("sdex_volume") @db.Decimal(36, 7)
  ammVolume   Decimal? @default(0) @map("amm_volume") @db.Decimal(36, 7)
  tradeCount  Int?     @default(0) @map("trade_count")
  openPrice   Decimal? @map("open_price") @db.Decimal(36, 18)
  closePrice  Decimal? @map("close_price") @db.Decimal(36, 18)
  highPrice   Decimal? @map("high_price") @db.Decimal(36, 18)
  lowPrice    Decimal? @map("low_price") @db.Decimal(36, 18)

  @@id([pairKey, window, bucket])
  @@map("price_aggregates")
}

model PriceSnapshot {
  pair   String
  ts     DateTime
  price  Decimal  @db.Decimal(36, 18)
  volume Decimal  @default(0) @db.Decimal(36, 7)

  @@id([pair, ts])
  @@index([pair, ts])
  @@map("price_snapshots")
}

model IndexerState {
  id              String    @id
  lastCursor      String?   @map("last_cursor")
  lastLedger      Int?      @map("last_ledger")
  lastProcessedAt DateTime? @map("last_processed_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("indexer_state")
}

model PairConfig {
  pairKey   String   @id @map("pair_key")
  assetACode   String   @map("asset_a_code")
  assetAIssuer String?  @map("asset_a_issuer")
  assetBCode   String   @map("asset_b_code")
  assetBIssuer String?  @map("asset_b_issuer")
  addedAt   DateTime @default(now()) @map("added_at")

  @@map("pair_configs")
}

model Webhook {
  id        String   @id @default(uuid())
  url       String
  assetA    String   @map("asset_a")
  assetB    String   @map("asset_b")
  threshold Float
  direction String
  secret    String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([assetA, assetB])
  @@map("webhooks")
}

model ApiKey {
  id         String    @id @default(uuid())
  hash       String    @unique
  label      String
  ratePerMin Int       @default(60) @map("rate_per_min")
  ratePerDay Int       @default(10000) @map("rate_per_day")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("api_keys")
}
